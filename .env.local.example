# Opcional: URL do Google Apps Script para sync com Google Sheets
# Deixe vazio para usar apenas localStorage (padrão)
NEXT_PUBLIC_GAS_URL=

# Opcional: protege o app publicado com autenticação básica gratuita
# Configure valores reais apenas em .env.local ou nas variáveis da Vercel.
APP_BASIC_AUTH_USER=
APP_BASIC_AUTH_PASSWORD=
